# Token Trust Score ASP — environment
# Copy to .env and fill in.

# Your receiving address on X Layer (must match the Agentic Wallet you register with).
PAY_TO_ADDRESS=0xYourXLayerAddress

# Price per call in USD (settled in USDC on X Layer).
PRICE_USD=0.01

# Public base URL of this service (used in agent card + resource metadata).
# For local dev you can use ngrok or similar to expose a public URL.
PUBLIC_URL=http://localhost:3000

# x402 facilitator (OKX Onchain OS uses the public one; override for testing).
X402_FACILITATOR=https://facilitator.x402.org

# Optional: override the X Layer USDC settlement asset (verified X Layer native USDC).
# USDC_XLAYER=0x74b7f16337b8972027f6196a17a631ac6de26d22

# Signal providers (no key needed for the default free tier):
# - GoPlus Labs token security API
# - DexScreener liquidity API
# Optional custom indexer hook (POST {chain,address} -> RawSignals JSON).
# OKX_ONCHAIN_API_URL=

